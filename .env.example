# Navidrome Scripts Configuration
# Copy this file to .env and fill in your values

# ===================
# Directory Paths
# ===================
# Where downloaded songs are initially placed
INCOMING_DIR=/opt/navidrome/incoming/

# Main music library directory
MUSIC_DIR=/opt/navidrome/music/

# Directory to store lyrics files
LYRICS_DIR=/opt/navidrome/lyrics/

# ===================
# Telegram API Credentials
# ===================
# Get these from https://my.telegram.org
TG_API_ID=your_api_id_here
TG_API_HASH=your_api_hash_here

# Telegram session name (no extension)
TG_SESSION_NAME=deezer_music_downloader

# Deezer bot username on Telegram
DEEZER_BOT_USERNAME=@deezload2bot

# ===================
# Watcher Configuration
# ===================
# Path to main music downloader script
MAIN_DOWNLOADER_SCRIPT=/root/scripts/music_downloader.py

# Path to secondary YouTube downloader script
YT_DOWNLOADER_SCRIPT=/root/scripts/yt_downloader2.py

# Path to SoundCloud downloader script
SC_DOWNLOADER_SCRIPT=/root/scripts/sc_downloader.py

# How often to check for new songs (in seconds)
CHECK_INTERVAL_SECONDS=15

# ===================
# Playlist URLs (for watcher.py)
# ===================
# Leave empty to disable a source. You can also override these via command-line arguments.

# YouTube playlist URL (for main downloader using Deezer bot)
YOUTUBE_PLAYLIST_URL=

# ListenBrainz playlist URL
LISTENBRAINZ_PLAYLIST_URL=

# YouTube playlist URL (for yt_downloader2.py - direct YouTube download)
YT2_PLAYLIST_URL=

# SoundCloud playlist/user URL
SOUNDCLOUD_PLAYLIST_URL=

# ===================
# Misc
# ===================
# User agent for API requests
USER_AGENT=MusicDownloadScript/1.0 ( your-email@example.com )
