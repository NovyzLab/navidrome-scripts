# Environment files with secrets
.env

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Session files (contain auth tokens)
*.session
*.session-journal

# Byte-compiled / optimized / DLL files
*.pyc

# Data files (state tracking)
data/*.json
data/*.session
!data/.gitkeep

# IDE
.idea/
.vscode/
*.swp
*.swo
